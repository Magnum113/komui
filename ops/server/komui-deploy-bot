def curl_config_value(value: str) -> str:
    return value.replace("\\", "\\\\").replace('"', '\\"')


def curl_api(method: str, fields: dict[str, Any], max_time: int | None = None) -> dict[str, Any]:
    # Keep the Telegram token and optional proxy credentials out of argv so
    # they are not visible to local users through `ps` or /proc/*/cmdline.
    config = [f'url = "{curl_config_value(f"{API_BASE}/{method}")}"']
    if PROXY_URL:
        config.append(f'proxy = "{curl_config_value(PROXY_URL)}"')
    args = ["curl", "-fsS", "--max-time", str(max_time or int(TIMEOUT_SECONDS)), "--config", "-"]
    for key, value in fields.items():
        if isinstance(value, (dict, list)):
            value = json.dumps(value, ensure_ascii=False)
        args += ["-d", f"{key}={value}"]
    proc = subprocess.run(
        args,
        input="\n".join(config) + "\n",
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=True,
    )
    response = json.loads(proc.stdout)
    if response.get("ok") is not True:
        raise RuntimeError(f"Telegram API {method} failed: {response.get('description', 'unknown error')}")
    return response


def send_message(text: str, reply_markup: dict[str, Any] | None = None) -> None:
    max_len = 3900
    chunks = [text[i : i + max_len] for i in range(0, len(text), max_len)] or [text]
    for index, chunk in enumerate(chunks):
        fields: dict[str, Any] = {
            "chat_id": ALLOWED_CHAT_ID,
            "text": chunk,
            "disable_web_page_preview": "true",
        }
        if index == len(chunks) - 1 and reply_markup:
            fields["reply_markup"] = reply_markup
        curl_api("sendMessage", fields)


def answer_callback(callback_id: str, text: str) -> None:
    curl_api("answerCallbackQuery", {"callback_query_id": callback_id, "text": text, "show_alert": "false"})


def configure_bot_ui() -> None:
    curl_api("setMyCommands", {"commands": BOT_COMMANDS})
    curl_api("setChatMenuButton", {"menu_button": {"type": "commands"}})


def keyboard() -> dict[str, Any]:
