#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import subprocess
import sys
import time
from pathlib import Path
from typing import Any


ENV_PATH = Path(os.environ.get("KOMUI_TELEGRAM_ENV", "/etc/komui/telegram-alerts.env"))
DEPLOY_BIN = Path(os.environ.get("KOMUI_DEPLOY_BIN", "/usr/local/sbin/komui-deploy-from-git"))
STATUS_BIN = Path(os.environ.get("KOMUI_DEPLOY_STATUS_BIN", "/usr/local/sbin/komui-deploy-status"))
ADMIN_DEPLOY_BIN = Path(os.environ.get("GETOMERCH_DEPLOY_BIN", "/usr/local/sbin/getomerch-deploy-from-git"))
ADMIN_STATUS_BIN = Path(os.environ.get("GETOMERCH_STATUS_BIN", "/usr/local/sbin/getomerch-deploy-status"))
ADMIN_ROLLBACK_BIN = Path(os.environ.get("GETOMERCH_ROLLBACK_BIN", "/usr/local/sbin/getomerch-rollback"))


def load_env(path: Path) -> dict[str, str]:
    env: dict[str, str] = {}
    for raw in path.read_text().splitlines():
        line = raw.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        env[key.strip()] = value.strip().strip('"').strip("'")
    return env


ENV = load_env(ENV_PATH)
TOKEN = ENV["TELEGRAM_BOT_TOKEN"]
ALLOWED_CHAT_ID = str(ENV["TELEGRAM_CHAT_ID"])
PROXY_URL = ENV.get("TELEGRAM_PROXY_URL", "")
TIMEOUT_SECONDS = str(int(ENV.get("TELEGRAM_TIMEOUT_SECONDS", "15")))
API_BASE = f"https://api.telegram.org/bot{TOKEN}"
STAGE_BUTTON = "🚀 Deploy stage"
PROD_BUTTON = "🚀 Deploy prod"
STATUS_BUTTON = "📦 Status"
ADMIN_DEPLOY_BUTTON = "Deploy admin prod"
ADMIN_STATUS_BUTTON = "Status admin prod"
ADMIN_ROLLBACK_BUTTON = "Rollback admin prod"


def curl_api(method: str, fields: dict[str, Any], max_time: int | None = None) -> dict[str, Any]:
    args = ["curl", "-fsS", "--max-time", str(max_time or int(TIMEOUT_SECONDS))]
    if PROXY_URL:
        args += ["--proxy", PROXY_URL]
    args += [f"{API_BASE}/{method}"]
    for key, value in fields.items():
        if isinstance(value, (dict, list)):
            value = json.dumps(value, ensure_ascii=False)
        args += ["-d", f"{key}={value}"]
    raw = subprocess.check_output(args, text=True)
    return json.loads(raw)


def send_message(text: str, reply_markup: dict[str, Any] | None = None) -> None:
    max_len = 3900
    chunks = [text[i : i + max_len] for i in range(0, len(text), max_len)] or [text]
    for index, chunk in enumerate(chunks):
        fields: dict[str, Any] = {
            "chat_id": ALLOWED_CHAT_ID,
            "text": chunk,
            "disable_web_page_preview": "true",
        }
        if index == len(chunks) - 1 and reply_markup:
            fields["reply_markup"] = reply_markup
        curl_api("sendMessage", fields)


def answer_callback(callback_id: str, text: str) -> None:
    curl_api("answerCallbackQuery", {"callback_query_id": callback_id, "text": text, "show_alert": "false"})


def keyboard() -> dict[str, Any]:
    return {
        "keyboard": [
            [{"text": STAGE_BUTTON}, {"text": PROD_BUTTON}],
            [{"text": STATUS_BUTTON}],
            [{"text": ADMIN_DEPLOY_BUTTON}, {"text": ADMIN_STATUS_BUTTON}],
            [{"text": ADMIN_ROLLBACK_BUTTON}],
        ],
        "resize_keyboard": True,
        "one_time_keyboard": False,
        "is_persistent": True,
        "input_field_placeholder": "Выбери deploy-действие",
    }


def inline_keyboard() -> dict[str, Any]:
    return {
        "inline_keyboard": [
            [
                {"text": STAGE_BUTTON, "callback_data": "deploy:stage"},
                {"text": PROD_BUTTON, "callback_data": "deploy:prod"},
            ],
            [{"text": STATUS_BUTTON, "callback_data": "status"}],
            [
                {"text": ADMIN_DEPLOY_BUTTON, "callback_data": "admin:deploy:prod"},
                {"text": ADMIN_STATUS_BUTTON, "callback_data": "admin:status:prod"},
            ],
            [{"text": ADMIN_ROLLBACK_BUTTON, "callback_data": "admin:rollback:prod"}],
        ]
    }


def is_allowed_chat(update: dict[str, Any]) -> bool:
    message = update.get("message") or {}
    callback = update.get("callback_query") or {}
    callback_message = callback.get("message") or {}
    chat = message.get("chat") or callback_message.get("chat") or {}
    return str(chat.get("id", "")) == ALLOWED_CHAT_ID


def run_command(args: list[str], timeout: int) -> tuple[int, str]:
    env = os.environ.copy()
    # The bot sends its own start/result messages. Keep deployment-registry
    # Telegram notifications enabled for manual SSH deploys only to avoid
    # duplicate release messages after button-triggered deploys.
    env["KOMUI_DEPLOY_REGISTRY_NOTIFY"] = "0"
    proc = subprocess.run(args, text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, timeout=timeout, env=env)
    return proc.returncode, proc.stdout


def parse_status_output(output: str) -> dict[str, dict[str, str]]:
    sections: dict[str, dict[str, str]] = {"root": {}}
    section = "root"
    known_sections = {
        "active releases": "releases",
        "services": "services",
        "smoke": "smoke",
    }
    for raw_line in output.splitlines():
        line = raw_line.strip()
        if not line or line == "KOMUI deploy status":
            continue
        lower = line.rstrip(":").lower()
        if lower in known_sections and line.endswith(":"):
            section = known_sections[lower]
            sections.setdefault(section, {})
            continue
        if ":" not in line:
            continue
        key, value = line.split(":", 1)
        sections.setdefault(section, {})[key.strip()] = value.strip()
    return sections


def ok_icon(value: str, *, expected: str = "active") -> str:
    return "✅" if value == expected else "❌"


def http_icon(value: str) -> str:
    return "✅" if value == "200" else "❌"


def format_service_status(name: str, value: str) -> str:
    labels = {
        "postgresql": "PostgreSQL / база",
        "nginx": "Nginx / сайт",
        "komui-backend": "Stage backend",
        "komui-production-backend": "Prod backend",
        "komui-backup.timer": "Автобэкапы",
        "komui-healthcheck.timer": "Healthcheck",
        "komui-deploy-bot": "Telegram deploy bot",
    }
    label = labels.get(name, name)
    return f"{ok_icon(value)} {label}: {value}"


def format_status_message(output: str, code: int) -> str:
    try:
        data = parse_status_output(output)
        root = data.get("root", {})
        releases = data.get("releases", {})
        services = data.get("services", {})
        smoke = data.get("smoke", {})

        local = root.get("local", "unknown")
        origin = root.get("origin/main", "unknown")
        branch = root.get("branch", "unknown")

        critical_services = [
            "postgresql",
            "nginx",
            "komui-backend",
            "komui-production-backend",
            "komui-deploy-bot",
        ]
        services_ok = all(services.get(unit) == "active" for unit in critical_services)
        smoke_ok = smoke.get("stage products") == "200" and smoke.get("prod products") == "200"
        git_known = local not in ("", "unknown") and origin not in ("", "unknown")
        git_synced = git_known and local == origin

        if code != 0:
            verdict = f"⚠️ Status-команда завершилась с ошибкой exit={code}."
        elif services_ok and smoke_ok and git_synced:
            verdict = "✅ Всё штатно. Stage и prod отвечают, основные сервисы активны."
        elif services_ok and smoke_ok and git_known and not git_synced:
            verdict = "⚠️ Сайт работает, но в GitHub есть версия, которую сервер ещё не развернул."
        elif services_ok and smoke_ok:
            verdict = "✅ Сайт отвечает, основные сервисы активны. Git-состояние нужно проверить отдельно."
        else:
            verdict = "❌ Есть проблема в сервисах или smoke-check’ах. Перед релизом лучше проверить логи."

        if git_synced:
            git_line = "✅ Серверная deploy-копия совпадает с origin/main."
        elif git_known:
            git_line = "⚠️ origin/main отличается от серверной deploy-копии. Нажатие Deploy подтянет origin/main."
        else:
            git_line = "⚠️ Git-состояние не удалось определить полностью."

        service_lines = [
            format_service_status("postgresql", services.get("postgresql", "unknown")),
            format_service_status("nginx", services.get("nginx", "unknown")),
            format_service_status("komui-backend", services.get("komui-backend", "unknown")),
            format_service_status("komui-production-backend", services.get("komui-production-backend", "unknown")),
            format_service_status("komui-backup.timer", services.get("komui-backup.timer", "unknown")),
            format_service_status("komui-healthcheck.timer", services.get("komui-healthcheck.timer", "unknown")),
            format_service_status("komui-deploy-bot", services.get("komui-deploy-bot", "unknown")),
        ]

        if git_known and not git_synced and services_ok and smoke_ok:
            next_step = "Что делать: сначала нажми Deploy stage, проверь stage. Потом, если всё нормально, нажми Deploy prod."
        elif services_ok and smoke_ok:
            next_step = "Что делать: можно деплоить новые изменения, когда они будут запушены в GitHub."
        else:
            next_step = "Что делать: не запускай prod deploy, пока не будет понятно, почему есть красные статусы."

        return "\n".join(
            [
                "📦 Статус KOMUI",
                "",
                verdict,
                "",
                "Git:",
                f"• ветка: {branch}",
                f"• серверная deploy-копия: {local}",
                f"• GitHub origin/main: {origin}",
                f"• {git_line}",
                "",
                "🧪 Stage:",
                f"• backend release: {releases.get('stage backend', 'unknown')}",
                f"• frontend release: {releases.get('stage frontend', 'unknown')}",
                f"• API товаров: {http_icon(smoke.get('stage products', ''))} {smoke.get('stage products', 'unknown')}",
                "",
                "🚀 Prod:",
                f"• backend release: {releases.get('prod backend', 'unknown')}",
                f"• frontend release: {releases.get('prod frontend', 'unknown')}",
                f"• API товаров: {http_icon(smoke.get('prod products', ''))} {smoke.get('prod products', 'unknown')}",
                "",
                "Сервисы:",
                *service_lines,
                "",
                next_step,
            ]
        )
    except Exception:
        prefix = "📦 Status" if code == 0 else f"⚠️ Status failed exit={code}"
        return f"{prefix}\n\n{output}"


def handle_deploy(target: str) -> None:
    label = "stage" if target == "stage" else "prod"
    send_message(f"⏳ Начинаю deploy `{label}` из `origin/main`.")
    started = time.time()
    code, output = run_command([str(DEPLOY_BIN), target, "main"], timeout=1800)
    elapsed = int(time.time() - started)
    tail = "\n".join(output.splitlines()[-80:])
    if code == 0:
        send_message(f"✅ Deploy `{label}` завершён за {elapsed}s.\n\nПоследние строки:\n{tail}", inline_keyboard())
    else:
        send_message(f"❌ Deploy `{label}` упал за {elapsed}s, exit={code}.\n\nПоследние строки:\n{tail}", inline_keyboard())


def handle_status() -> None:
    code, output = run_command([str(STATUS_BIN)], timeout=60)
    send_message(format_status_message(output, code), inline_keyboard())


def format_admin_status_message(output: str, code: int) -> str:
    prefix = "📦 Статус GetoMerch admin" if code == 0 else f"⚠️ GetoMerch admin status failed exit={code}"
    body = output.strip() or "Нет вывода."
    return f"{prefix}\n\n{body}"


def handle_admin_deploy() -> None:
    send_message("⏳ Начинаю deploy `admin prod` из `origin/main`.")
    started = time.time()
    code, output = run_command([str(ADMIN_DEPLOY_BIN), "prod", "main"], timeout=1800)
    elapsed = int(time.time() - started)
    tail = "\n".join(output.splitlines()[-80:])
    if code == 0:
        send_message(f"✅ Deploy `admin prod` завершён за {elapsed}s.\n\nПоследние строки:\n{tail}", inline_keyboard())
    else:
        send_message(f"❌ Deploy `admin prod` упал за {elapsed}s, exit={code}.\n\nПоследние строки:\n{tail}", inline_keyboard())


def handle_admin_status() -> None:
    code, output = run_command([str(ADMIN_STATUS_BIN)], timeout=60)
    send_message(format_admin_status_message(output, code), inline_keyboard())


def handle_admin_rollback() -> None:
    send_message("⏳ Начинаю rollback `admin prod` на предыдущий успешный release.")
    started = time.time()
    code, output = run_command([str(ADMIN_ROLLBACK_BIN), "prod"], timeout=900)
    elapsed = int(time.time() - started)
    tail = "\n".join(output.splitlines()[-80:])
    if code == 0:
        send_message(f"✅ Rollback `admin prod` завершён за {elapsed}s.\n\nПоследние строки:\n{tail}", inline_keyboard())
    else:
        send_message(f"❌ Rollback `admin prod` упал за {elapsed}s, exit={code}.\n\nПоследние строки:\n{tail}", inline_keyboard())


def handle_update(update: dict[str, Any]) -> None:
    if not is_allowed_chat(update):
        callback = update.get("callback_query") or {}
        if callback.get("id"):
            answer_callback(callback["id"], "Not allowed")
        return

    if "message" in update:
        text = str(update["message"].get("text") or "").strip()
        if text in ("/start", "/deploy", "/menu"):
            send_message("KOMUI deploy bot. Выбери действие:", inline_keyboard())
        elif text in ("/status", STATUS_BUTTON):
            handle_status()
        elif text == STAGE_BUTTON:
            handle_deploy("stage")
        elif text == PROD_BUTTON:
            handle_deploy("prod")
        elif text == ADMIN_DEPLOY_BUTTON:
            handle_admin_deploy()
        elif text == ADMIN_STATUS_BUTTON:
            handle_admin_status()
        elif text == ADMIN_ROLLBACK_BUTTON:
            handle_admin_rollback()
        return

    callback = update.get("callback_query") or {}
    data = str(callback.get("data") or "")
    callback_id = str(callback.get("id") or "")
    if data == "status":
        answer_callback(callback_id, "Checking status")
        handle_status()
    elif data == "deploy:stage":
        answer_callback(callback_id, "Stage deploy started")
        handle_deploy("stage")
    elif data == "deploy:prod":
        answer_callback(callback_id, "Prod deploy started")
        handle_deploy("prod")
    elif data == "admin:deploy:prod":
        answer_callback(callback_id, "Admin prod deploy started")
        handle_admin_deploy()
    elif data == "admin:status:prod":
        answer_callback(callback_id, "Checking admin prod status")
        handle_admin_status()
    elif data == "admin:rollback:prod":
        answer_callback(callback_id, "Admin prod rollback started")
        handle_admin_rollback()


def get_updates(offset: int) -> list[dict[str, Any]]:
    poll_timeout = 50
    fields = {
        "timeout": str(poll_timeout),
        "offset": str(offset),
        "allowed_updates": json.dumps(["message", "callback_query"]),
    }
    return curl_api("getUpdates", fields, max_time=poll_timeout + 15).get("result", [])


def main() -> int:
    send_message("✅ KOMUI deploy bot запущен.", inline_keyboard())
    offset = 0
    while True:
        try:
            updates = get_updates(offset)
            for update in updates:
                offset = max(offset, int(update["update_id"]) + 1)
                handle_update(update)
        except subprocess.CalledProcessError as exc:
            print(f"telegram_api_error exit={exc.returncode} output={exc.output}", file=sys.stderr, flush=True)
            time.sleep(5)
        except Exception as exc:
            print(f"bot_error {type(exc).__name__}: {exc}", file=sys.stderr, flush=True)
            time.sleep(5)


if __name__ == "__main__":
    raise SystemExit(main())
