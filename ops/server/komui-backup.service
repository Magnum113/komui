[Unit]
Description=KOMUI encrypted local backup
Documentation=file:/usr/local/sbin/komui-backup
Wants=postgresql.service
After=postgresql.service

[Service]
Type=oneshot
User=root
Group=root
ExecStart=/usr/local/sbin/komui-backup
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7
PrivateTmp=true
ProtectHome=true
ReadWritePaths=/var/backups/komui /etc/komui
