#!/usr/bin/env bash
set -Eeuo pipefail

umask 077

if [[ "${EUID}" -ne 0 ]]; then
  echo "Run with sudo: sudo /usr/local/sbin/komui-configure-telegram-alerts" >&2
  exit 1
fi

read -r -s -p "Telegram bot token: " token
echo
read -r -p "Telegram chat_id (leave empty to detect from getUpdates): " chat_id
read -r -p "Proxy URL, optional (socks5h://user:pass@host:port or http://user:pass@host:port): " proxy_url

if [[ -z "$token" ]]; then
  echo "Telegram bot token is required." >&2
  exit 1
fi

if [[ -z "$chat_id" ]]; then
  echo "Trying to detect chat_id via getUpdates."
  echo "If this fails: open Telegram, send any message to your bot, then run this command again."
  curl_args=(-fsS --max-time 15)
  if [[ -n "$proxy_url" ]]; then
    curl_args+=(--proxy "$proxy_url")
  fi
  updates="$(curl "${curl_args[@]}" "https://api.telegram.org/bot${token}/getUpdates")"
  chat_id="$(UPDATES_JSON="$updates" python3 - <<'PY'
import json, os
payload = json.loads(os.environ["UPDATES_JSON"])
updates = payload.get("result") or []
for update in reversed(updates):
    message = update.get("message") or update.get("channel_post") or update.get("edited_message")
    if message and "chat" in message:
        print(message["chat"]["id"])
        raise SystemExit
raise SystemExit("No chat_id found in getUpdates")
PY
)"
  echo "Detected chat_id: $chat_id"
fi

install -d -m 0700 /etc/komui
tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT

{
  printf 'TELEGRAM_BOT_TOKEN=%q\n' "$token"
  printf 'TELEGRAM_CHAT_ID=%q\n' "$chat_id"
  if [[ -n "$proxy_url" ]]; then
    printf 'TELEGRAM_PROXY_URL=%q\n' "$proxy_url"
  fi
  printf 'TELEGRAM_TIMEOUT_SECONDS=%q\n' "15"
} > "$tmp"

install -o root -g root -m 0600 "$tmp" /etc/komui/telegram-alerts.env
echo "Saved /etc/komui/telegram-alerts.env with root-only permissions."

if /usr/local/sbin/komui-alert "KOMUI test alert" "Telegram alerting configured."; then
  echo "Test alert sent."
else
  echo "Config saved, but test alert failed. Check token/chat_id and network." >&2
  exit 2
fi
